# ── Required ───────────────────────────────────────────────────────────────────
E2B_API_KEY=
# Sandbox lifetime in seconds; refreshed on every tool call (rolling keep-alive).
# Raise for very long builds. Default 1800 (30 min).
# SANDBOX_TIMEOUT=1800
OPENROUTER_API_KEY=
# Any OpenRouter slug, e.g. anthropic/claude-sonnet-4-5, openai/gpt-4o, deepseek/deepseek-coder
OPENROUTER_MODEL=deepseek/deepseek-coder
# Comma-separated fallback chain: if the primary model errors/429s, OpenRouter routes to
# the next. Must be tool-calling capable. Default: deepseek/deepseek-v4-flash
# OPENROUTER_FALLBACK_MODELS=deepseek/deepseek-v4-flash

# ── Persistence (optional) ───────────────────────────────────────────────────────
# Under Docker Compose, DATABASE_URL and ARTIFACT_DIR are supplied by docker-compose.yml
# (Postgres + a persistent volume) — you do NOT need to set them here. Only the API
# keys above are required for Compose.
#
# For a non-Docker / local run: leave DATABASE_URL empty for "DB-less mode" (core
# agents/skills/tools work, but custom agents, conversation history, memory, and
# artifact metadata are not saved), or point it at your own Postgres.
# DATABASE_URL=postgresql://user:pass@localhost:5432/agentplatform
# EMBEDDING_MODEL=openai/text-embedding-3-small

# ── Artifacts ────────────────────────────────────────────────────────────────────
# Where rendered videos/images/PDFs are stored (served via /artifacts/{id}/download).
# ARTIFACT_DIR=./artifact_store

# ── Text-to-speech (optional voiceover for the Infographic Video agent) ───────────
# OpenAI-compatible /audio/speech endpoint. If unset, videos render silently.
# TTS_API_KEY=
# TTS_BASE_URL=https://api.openai.com/v1
# TTS_MODEL=tts-1

# ── Misc ─────────────────────────────────────────────────────────────────────────
# DEFAULT_AGENT=coding_agent
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Langfuse observability (optional) ────────────────────────────────────────
# Get keys from cloud.langfuse.com (or your self-hosted instance).
# Leave blank to disable tracing entirely — the app runs fine without it.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Web search (lead generation / GTM / research agents) ─────────────────────
# Provider for the web_search tool. Without a key the tool reports it's unconfigured.
# SEARCH_PROVIDER=tavily            # tavily | serper
# SEARCH_API_KEY=tvly-...           # Tavily key (or Serper key if SEARCH_PROVIDER=serper)
